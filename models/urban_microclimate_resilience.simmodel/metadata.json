{
  "name": "Urban Microclimate Resilience",
  "description": "High-detail urban climate-hydrology simulation coupling radiative forcing, turbulent exchange, evapotranspiration, runoff partitioning, and thermal storage dynamics on a 2D city grid.",
  "author": "Colin Bossu Réaubourg",
  "creation_date": "2026-04-02",
  "tags": [
    "urban-climate",
    "heat-island",
    "hydrology",
    "resilience",
    "coupled-system",
    "pde"
  ],
  "initialization_guidance": {
    "preferred_mode": "terrain",
    "expected_start_data_type": "continuous_field",
    "supported_modes": ["terrain", "waves", "blank"],
    "preferred_display_variable": "surface_temperature",
    "parameter_overrides": {
      "terrainBaseFrequency": 1.8,
      "terrainDetailFrequency": 5.8,
      "terrainWarpStrength": 0.45,
      "seaLevel": 0.40,
      "humidityFromWater": 0.68,
      "waveBaseline": 300.0,
      "waveDropAmplitude": 3.0,
      "waveDropRadius": 26.0
    },
    "variable_defaults": {
      "surface_albedo": {
        "enabled": true,
        "base_value": 0.18,
        "restriction_mode": "clamp",
        "min": 0.0,
        "max": 1.0
      },
      "emissivity_surface": {
        "enabled": true,
        "base_value": 0.95,
        "restriction_mode": "clamp",
        "min": 0.0,
        "max": 1.0
      },
      "impervious_fraction": {
        "enabled": true,
        "base_value": 0.72,
        "restriction_mode": "clamp",
        "min": 0.0,
        "max": 1.0
      },
      "vegetation_fraction": {
        "enabled": true,
        "base_value": 0.28,
        "restriction_mode": "clamp",
        "min": 0.0,
        "max": 1.0
      },
      "surface_temperature": {
        "enabled": true,
        "base_value": 302.0,
        "restriction_mode": "clamp",
        "min": 230.0,
        "max": 360.0
      },
      "canopy_temperature": {
        "enabled": true,
        "base_value": 299.0,
        "restriction_mode": "clamp",
        "min": 230.0,
        "max": 360.0
      },
      "soil_moisture": {
        "enabled": true,
        "base_value": 0.34,
        "restriction_mode": "clamp",
        "min": 0.0,
        "max": 1.0
      },
      "storage_heat": {
        "enabled": true,
        "base_value": 12000.0,
        "restriction_mode": "non_negative",
        "min": 0.0,
        "max": 1000000000.0
      }
    }
  },
  "runtime_field_aliases": {
    "urban.temperature": "surface_temperature",
    "urban.current": "surface_temperature",
    "urban.canopy": "canopy_temperature",
    "urban.moisture": "soil_moisture",
    "urban.water": "soil_moisture",
    "urban.heat_storage": "storage_heat",
    "urban.radiation": "net_radiation",
    "urban.sensible_heat": "sensible_flux",
    "urban.latent_heat": "latent_flux",
    "urban.runoff": "runoff_flux",
    "climate.temperature": "surface_temperature",
    "climate.current": "surface_temperature",
    "hydrology.moisture": "soil_moisture",
    "hydrology.water": "soil_moisture",
    "hydrology.runoff": "runoff_flux",
    "temperature.current": "surface_temperature",
    "temperature.canopy": "canopy_temperature",
    "moisture.current": "soil_moisture",
    "moisture.urban": "soil_moisture"
  }
}
